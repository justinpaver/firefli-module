end

function Firefli:CreateUnscheduledSessionWithExistingSessionType(info: {
	sessionTypeId:string,
	date:string,
	time:string,
	ownerId:string
	})
	return makeRequest(self, "/sessions/create-unscheduled", "POST", info)
end

function Firefli:CreateUnscheduledSessionWithNewSessionType(info: {
	sessionType: {
		name: string,
		description: string,
		slots: { { id: string, name: string, number: number } },
		statues: { { id: string, name: string } }
	},
	date: string,
	time: string,
	ownerId: string
	})
	return makeRequest(self, "/sessions/create-unscheduled", "POST", info)
end

function Firefli:CreateScheduledSessionFromId(info: {
	scheduleId: string,
	date: string
	})
	return makeRequest(self, "/sessions/create-scheduled", "POST", info)
end

function Firefli:CreateScheduledSessionWithNewType(info: {
	sessionType: {
		name: string,
		description: string,
		slots: { { id: string, name: string, number: number } },
		schedule: {
			days: { number }, -- Array of days (e.g., 1 for Monday, 3 for Wednesday)
			hour: number,
			minute: number
		}
	},
	date: string
	})
	return makeRequest(self, "/sessions/create-scheduled", "POST", info)
end

