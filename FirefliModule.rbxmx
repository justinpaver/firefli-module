 |_| |_|_| \___|_| |_|_|

 Firefli Module
 
 To initialise the module from a script, you simply have to call this module via:
 local Firefli = require(path.to.Firefli).new(workspaceId, apiKey)
 
 You can then call methods via Firefli:methodName(data) or Firefli:methodName() if the method does not require data, for example:
 
 Firefli:GetWorkspaceInfo()
 Firefli:CreateNotice({
 	userId = 1234567890,
 	startTime = 
 })
 
 For a full list of methods, see below. Don't modify this file UNLESS you know what you're doing.
 Usage of this module assumes you have development knowledge.
 Don't know how to code? Don't use the module, or you can ask AI how to use it.

 Made by stcteside, 2026

]]

local HttpService = game:GetService("HttpService")
local BaseUrl = "https://app.firefli.net/api/public/v1/workspace/"

local Firefli = {}
Firefli.__index = Firefli

function Firefli.new(workspaceId, apiKey)
	if typeof(apiKey) ~= "string" then
		error("API key must be a string")
	end
	if typeof(workspaceId) ~= "number" then
		error("Workspace ID must be a number")
	end

	local self = setmetatable({}, Firefli)
	self.ApiKey = apiKey
	self.WorkspaceId = workspaceId
	return self
end

--         [ HELPER FUNCTION TO MAKE REQUESTS ]         --

local function makeRequest(self, endpoint, method, data)
	local headers = {
		["Authorization"] = "Bearer " .. self.ApiKey,
		["Content-Type"] = "application/json"
	}

	local url = string.format("%s%d%s", BaseUrl, self.WorkspaceId, endpoint)

	local success, response = pcall(function()
		return HttpService:RequestAsync({
			Url = url,
			Method = method,
			Headers = headers,
			Body = data and HttpService:JSONEncode(data) or nil
		})
	end)

	if not success then
		warn("[Firefli API] Network Error: " .. tostring(response))
		return nil, "Network Error"
	end

	local decodeSuccess, decodedBody = pcall(function()
		return HttpService:JSONDecode(response.Body)
	end)

	if response.Success then
		return decodedBody, nil
	else
		local errorMessage = decodeSuccess and decodedBody or response.StatusMessage
		warn(string.format("[Firefli API] HTTP %d: %s", response.StatusCode, tostring(errorMessage)))
		return nil, errorMessage
	end
end

--         [ GENERAL METHODS ]         --

function Firefli:GetWorkspaceInfo()
	return makeRequest(self, "/info", "GET")
end

function Firefli:GetLeaderboard()
	return makeRequest(self, "/leaderboard", "GET")
end

function Firefli:GetMembers()
	return makeRequest(self, "/members", "GET")
end

function Firefli:GetBirthdays()
	return makeRequest(self, "/birthdays", "GET")
end

--         [ ACTIVITY-RELATED METHODS ]         --

function Firefli:GetActivity()
	return makeRequest(self, "/activity", "GET")
end

function Firefli:GetUserActivity(userId:number)
	return makeRequest(self, "/user/" .. userId .. "/activity", "GET")
end

function Firefli:GetCurrentActivity(userId:number)
	return makeRequest(self, "/user/" .. userId .. "/pactivity", "GET")
end

function Firefli:StartActivity(userId:number, info: {
	time:string
	})
	return makeRequest(self, "/user/" .. userId .. "/activity/start", "POST", info)
end

function Firefli:EndActivity(userId:number, info: {
	time:string
	})
	return makeRequest(self, "/user/" .. userId .. "/activity/end", "POST", info)
end

