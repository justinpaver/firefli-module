	action:string,
	userId:string,
	roleId:string,
	slot:number
	})
	return makeRequest(self, "/sessions/" .. sessionId .. "/roles", "POST", info)
end

function Firefli:ChangeHost(sessionId:string, info: {
	ownerId:string
	})
